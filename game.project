[bootstrap]
main_collection = /main/main.collectionc

[script]
shared_state = 1

[display]
width = 720
height = 360
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = Desert_shooting_game

[graphics]
opengl_version_hint = 46
default_texture_min_filter = linear
default_texture_mag_filter = nearest

[tilemap]
max_tile_count = 4096

